# Keep the Fly build context small; bun install regenerates node_modules in the image.
node_modules
**/node_modules
.git
# dist/* (not `dist`) so the negation below can re-include the baked pinned catalog —
# the break-glass OBJECTCORE_SOURCE=file mode serves it from the image.
dist/*
!dist/marketplace.pinned.json
*.log
.scratch*
.scratch-registry.db*
.changeset
OC
