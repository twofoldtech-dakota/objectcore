{
  "name": "objectcore",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build:marketplace": "bun run scripts/build-marketplace.ts",
    "validate": "bun run scripts/build-marketplace.ts",
    "eval": "bun run scripts/eval.ts",
    "eval:record": "bun run scripts/eval-record.ts",
    "eval:trend": "bun run scripts/eval-trend.ts",
    "forge:scaffold": "bun run scripts/forge-scaffold.ts",
    "forge:meta": "bun run scripts/forge-meta.ts",
    "design:scaffold": "bun run scripts/design-scaffold.ts",
    "design:seed": "bun run scripts/design-seed.ts",
    "design:check": "bun run scripts/design-check.ts",
    "design:build": "bun run scripts/design-build.ts",
    "forge:improve": "bun run scripts/forge-improve.ts",
    "forge:suggest": "bun run scripts/forge-suggest.ts",
    "release:status": "bun run scripts/release-status.ts",
    "release:version": "bun run scripts/release-version.ts",
    "release:publish": "bun run scripts/release-publish.ts",
    "check:catalog": "bun run scripts/check-catalog.ts",
    "kb:add": "bun run scripts/kb-add.ts",
    "kb:curate": "bun run scripts/kb-curate.ts",
    "kb:search": "bun run scripts/kb-search.ts",
    "kb:index": "bun run scripts/kb-index.ts",
    "kb:check": "bun run scripts/kb-check.ts",
    "kb:verify": "bun run scripts/kb-verify.ts",
    "kb:cite": "bun run scripts/kb-cite.ts",
    "kb:stats": "bun run scripts/kb-stats.ts",
    "kb:mcp": "bun run packages/knowledge-mcp/src/main.ts",
    "check": "bunx tsc && bun run check:catalog && bun run kb:check && bun run design:check && bun test && bun run eval",
    "clean:git": "bun run scripts/clean-git.ts",
    "registry:dev": "bun run packages/registry-server/src/dev.ts",
    "registry:prod": "bun run packages/registry-server/src/prod.ts",
    "registry:ingest": "bun run scripts/registry-ingest.ts",
    "registry:publish": "bun run scripts/registry-publish.ts",
    "registry:smoke": "bun run scripts/registry-smoke.ts",
    "db:migrate": "bun run scripts/db-migrate.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@objectcore/registry-core": "workspace:*",
    "@objectcore/registry-db": "workspace:*",
    "@objectcore/design": "workspace:*",
    "@objectcore/eval": "workspace:*",
    "@objectcore/forge": "workspace:*",
    "@objectcore/release": "workspace:*",
    "@objectcore/knowledge": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "^5.6.0"
  }
}
