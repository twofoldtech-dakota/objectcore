  "evals/delegation.json": "{\n  \"cases\": [\n    {\n      \"prompt\": \"do Y\",\n      \"expect\": \"worker\"\n    },\n    {\n      \"prompt\": \"no\",\n      \"expect\": null\n    }\n  ]\n}\n",
