  ".claude-plugin/plugin.json": "{\n  \"name\": \"golden-full\",\n  \"version\": \"1.2.3\",\n  \"description\": \"A plugin exercising every emit branch.\",\n  \"author\": {\n    \"name\": \"twofoldtech-dakota\"\n  },\n  \"license\": \"Apache-2.0\",\n  \"keywords\": [\n    \"objectcore\",\n    \"full\"\n  ],\n  \"category\": \"workflow\",\n  \"repository\": \"https://github.com/twofoldtech-dakota/objectcore\"\n}\n",
  "agents/worker.md": "---\nname: worker\ndescription: Delegate when Y.\nmodel: claude-haiku-4-5\ntools: Read, Grep\n---\n# Worker\n\nReal agent body.\n",
  "commands/do-cmd.md": "---\ndescription: Do the cmd.\n---\n# /do-cmd\n\nCustom body.\n",
