  "hooks/hooks.json": "{\n  \"hooks\": {\n    \"PostToolUse\": [\n      {\n        \"matcher\": \"Bash\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"echo done\"\n          }\n        ]\n      }\n    ]\n  }\n}\n",
  "output-styles/styled.md": "---\nname: styled\ndescription: A style.\nkeep-coding-instructions: true\n---\n# Styled\n\nStyle body.\n",
