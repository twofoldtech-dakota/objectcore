{
  ".claude-plugin/plugin.json": "{\n  \"name\": \"golden-hooks\",\n  \"version\": \"0.0.1\",\n  \"description\": \"A hooks-only plugin.\",\n  \"license\": \"MIT\"\n}\n",
  "evals/output.json": "{\n  \"expectEntry\": {\n    \"version\": \"0.0.1\"\n  }\n}\n",
  "hooks/hooks.json": "{\n  \"hooks\": {\n    \"SessionStart\": [\n      {\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"echo hi\"\n          }\n        ]\n      }\n    ],\n    \"Stop\": [\n      {\n        \"hooks\": [\n          {\n            \"type\": \"prompt\",\n            \"prompt\": \"Did you capture a lesson?\"\n          }\n        ]\n      }\n    ]\n  }\n}\n"
}
